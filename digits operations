num = int(input())
sum, count, multiple, average, sum_first_last = 0, 0, 1, 0, 0
init_last_digit = num % 10
while num > 0:  # считаем сумму цифр
    last_digit = num % 10
    sum += last_digit
    count += 1
    multiple *= last_digit
    average = sum / count
    num = num // 10
first_digit = last_digit
sum_first_last = first_digit + init_last_digit
print(sum, count, multiple, average, first_digit, sum_first_last, sep="\n")